{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  },

  "Watcher": {
    "DropFolder":        "./drop",
    "DoneFolder":        "./done",
    "ErrorFolder":       "./error",
    "FileSettleDelayMs": 500
  },

  "Smtp": {
    "Host":        "smtp.example.com",
    "Port":        587,
    "UseTls":      true,
    "Username":    "your-smtp-user@example.com",
    "Password":    "YOUR_SMTP_PASSWORD",
    "FromAddress": "phishing-detector@example.com",
    "FromName":    "Mail Phishing Detector"
  },

  "Imap": {
    "Enabled":             false,
    "Host":                "imap.gmail.com",
    "Port":                993,
    "UseSsl":              true,
    "Username":            "scan@gmail.com",
    "Password":            "YOUR_GMAIL_APP_PASSWORD",
    "InboxFolder":         "INBOX",
    "ProcessedFolder":     "Processed",
    "ErrorFolder":         "Error",
    "PollIntervalSeconds": 30
  }
}
