## .NET / C# gitignore

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NuGet Packages
*.nupkg
*.snupkg
# NuGet Symbol Packages
*.symbols.nupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target
!**/[Pp]ackages/build/
# Uncomment if necessary; generally all build results should be ignored
#!**/[Pp]ackages/repositories.config
# NuGet v3's project.json files produces more ignorable files
*.nuget.props
*.nuget.targets

# Microsoft Azure Build Output
csx/
*.build.csdef

# Publish Web Output
*.[Pp]ublish.xml
*.azurePubxml

# Published output for Azure Web Sites
publish/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Visual Studio cache/options directory
.vs/
# Uncomment below to ignore Azure Functions build output
#publish/

# MSBuild Binary and Structured Log
*.binlog

# Visual Studio
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Visual Studio Code
.vscode/

# JetBrains Rider
.idea/
*.sln.iml

# ReSharper
_ReSharperCache/
*.DotSettings.user

# dotnet tools
.config/dotnet-tools.json

# User-specific files
*.dbmdl
*.jfm

# Windows image file caches
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Environment / secrets
.env
.env.*
appsettings.Development.json
appsettings.Local.json
appsettings.Secrets.json
secrets.json

# Temporary files
*~
*.tmp
*.temp
