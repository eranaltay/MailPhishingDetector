{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  },

  "Watcher": {
    "DropFolder":        "./drop",
    "DoneFolder":        "./done",
    "ErrorFolder":       "./error",
    "FileSettleDelayMs": 500
  },

  "Smtp": {
    "Host":        "smtp.example.com",
    "Port":        587,
    "UseTls":      true,
    "Username":    "your-smtp-user@example.com",
    "Password":    "YOUR_SMTP_PASSWORD",
    "FromAddress": "phishing-detector@example.com",
    "FromName":    "Mail Phishing Detector"
  }
}
